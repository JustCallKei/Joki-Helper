{
  "name": "helper-joko",
  "version": "1.0.0",
  "description": "Discord Ticket Bot, WhatsApp Helper, and Web Dashboard for Blox Fruits Joki",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "restart": "npx -y kill-port 3000 && nodemon src/index.js",
    "kill": "npx -y kill-port 3000",
    "db:init": "npx prisma db push && node src/prisma/seed.js"
  },
  "keywords": [
    "discord",
    "whatsapp",
